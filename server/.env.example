# Kopiera till .env för lokal körning (eller sätt som miljövariabler i Railway).

# Postgres-anslutning från Supabase (Project Settings → Database → Connection string → URI).
# Använd "Connection pooling"-strängen (port 6543) och byt ut [YOUR-PASSWORD].
DATABASE_URL=postgresql://postgres:PASSWORD@db.xxxxxxxx.supabase.co:6543/postgres

# Vilka webbplatser som får skicka resultat (kommaseparerat). Lämna som * under test.
ALLOWED_ORIGINS=https://games.nordhammer.se

# PORT sätts automatiskt av Railway. Lokalt används 3000 om den saknas.
